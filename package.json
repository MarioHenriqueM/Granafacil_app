{
  "name": "granafacil",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "GranaFacil — Motor de Crédito para a Economia Gig",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "preview:ui": "vite preview",
    "start": "node --import tsx src/api/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "smoke": "tsx scripts/smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prettier": "^3.2.5",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.19.3",
    "fastify": "^5.8.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  }
}
